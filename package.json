{
  "name": "oracle-amigo-sandbox-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Controlled personal-agent sandbox tool layer backed by Gondolin micro-VMs.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:agent": "tsx src/server.ts",
    "dev:ui": "vite --host 127.0.0.1",
    "dev:control-plane": "npm --prefix apps/control-plane run dev",
    "build:control-plane": "npm --prefix apps/control-plane run build",
    "start:control-plane": "npm --prefix apps/control-plane run start",
    "test:control-plane": "npm --prefix apps/control-plane test",
    "dev:admin-portal": "npm --prefix apps/admin-portal run dev",
    "build:admin-portal": "npm --prefix apps/admin-portal run build",
    "test:admin-portal": "npm --prefix apps/admin-portal test",
    "dev:notification-bridge": "dotnet run --project apps/notification-bridge-windows",
    "demo": "tsx examples/demo-personal-agent.ts",
    "demo:dry": "node --import ./scripts/register-dry-run.mjs --import tsx examples/demo-personal-agent.ts",
    "demo:single-device": "tsx scripts/demo-single-device.ts",
    "demo:loopback-two-agents": "tsx scripts/demo-loopback.ts",
    "test:e2e:relay": "tsx scripts/e2e-two-agent-relay-test.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.config.ts --reporter=verbose tests/LoopbackA2A.test.ts",
    "test:e2e:frontend:vitest": "npm test -- tests/ChatFrontendWorkflow.test.ts",
    "test:e2e:frontend:playwright": "playwright test --config playwright.config.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "start": "node dist/server.js",
    "build": "tsc && vite build",
    "build:all": "npm run build && npm run build:control-plane && npm run build:admin-portal"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@earendil-works/gondolin": "^0.12.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.10.8",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "sqlite-vec": "^0.1.9",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^7.3.3",
    "vitest": "^3.1.4"
  }
}
