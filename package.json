{
  "name": "oracle-amigo-sandbox-tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Controlled personal-agent sandbox tool layer backed by Gondolin micro-VMs.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx src/server.ts",
    "dev:agent": "tsx src/server.ts",
    "dev:ui": "vite --host 127.0.0.1",
    "dev:control-plane": "npm --prefix apps/control-plane run dev",
    "build:control-plane": "npm --prefix apps/control-plane run build",
    "start:control-plane": "npm --prefix apps/control-plane run start",
    "test:control-plane": "npm --prefix apps/control-plane test",
    "dev:admin-portal": "npm --prefix apps/admin-portal run dev",
    "build:admin-portal": "npm --prefix apps/admin-portal run build",
    "test:admin-portal": "npm --prefix apps/admin-portal test",
    "dev:notification-bridge": "dotnet run --project apps/notification-bridge-windows",
    "demo": "tsx examples/demo-personal-agent.ts",
    "demo:dry": "node --import ./scripts/register-dry-run.mjs --import tsx examples/demo-personal-agent.ts",
    "demo:single-device": "tsx scripts/demo-single-device.ts",
    "demo:loopback-two-agents": "tsx scripts/demo-loopback.ts",
    "test:e2e:relay": "tsx scripts/e2e-two-agent-relay-test.ts",
    "test:e2e:relay-message": "npm test -- tests/PeerRouting.test.ts tests/ChatPersistence.test.ts",
    "test:e2e:relay-file-search": "npm test -- tests/FileRequestParser.test.ts tests/FileRequestSearch.test.ts tests/ChatPersistence.test.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.config.ts --reporter=verbose tests/LoopbackA2A.test.ts",
    "test:ui": "vitest run --config vitest.ui.config.ts",
    "test:e2e:frontend:vitest": "npm test -- tests/ChatFrontendWorkflow.test.ts",
    "test:e2e:frontend:playwright": "playwright test --config playwright.config.mjs",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "start": "node dist/server.js",
    "build": "tsc && vite build",
    "build:all": "npm run build && npm run build:control-plane && npm run build:admin-portal"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.13",
    "@earendil-works/gondolin": "^0.12.0",
    "@heroui/react": "^3.1.0",
    "@heroui/styles": "^3.1.0",
    "@heroui/theme": "^2.4.26",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@radix-ui/react-use-controllable-state": "^1.2.3",
    "@rive-app/react-webgl2": "^4.29.0",
    "@tanstack/react-query": "^5.59.0",
    "@tanstack/react-table": "^8.20.5",
    "@tanstack/react-virtual": "^3.10.8",
    "@xyflow/react": "^12.11.0",
    "ai": "^6.0.198",
    "ansi-to-react": "^6.2.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dotenv": "^16.5.0",
    "embla-carousel-react": "^8.6.0",
    "fastify": "^5.3.3",
    "framer-motion": "^12.40.0",
    "fuse.js": "^7.4.2",
    "lucide-react": "^1.17.0",
    "marked": "^18.0.5",
    "motion": "^12.40.0",
    "nanoid": "^5.1.11",
    "pdf-lib": "^1.17.1",
    "radix-ui": "^1.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.17.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.2.0",
    "sqlite-vec": "^0.1.9",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.6.0",
    "tokenlens": "^1.3.1",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "axe-core": "^4.12.0",
    "jsdom": "^29.1.1",
    "resize-observer-polyfill": "^1.5.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^7.3.3",
    "vitest": "^3.1.4",
    "vitest-axe": "^0.1.0"
  }
}
