{
  "name": "@oracle-amigo/control-plane",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Oracle Amigo cloud control plane (multi-tenant registration, directory, presence, A2A relay, file transfer relay, admin)",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --config vitest.config.ts",
    "demo:two-laptop": "tsx scripts/demo-two-laptop.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@node-rs/argon2": "^2.0.2",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "jsonwebtoken": "^9.0.2",
    "otpauth": "^9.5.1",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
