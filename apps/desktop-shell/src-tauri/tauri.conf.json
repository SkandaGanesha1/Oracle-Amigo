{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Oracle Amigo",
  "version": "0.1.0",
  "identifier": "com.oracle-amigo.desktop-shell",
  "build": {
    "beforeDevCommand": "npm run dev:ui",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "",
    "frontendDist": "../../../public"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Oracle Amigo",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://127.0.0.1:* ws://127.0.0.1:*; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../../voice-launcher/src-tauri/icons/icon.ico"],
    "externalBin": []
  }
}
