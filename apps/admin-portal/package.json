{
  "name": "@oracle-amigo/admin-portal",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Standalone Admin Portal: serves the admin SPA on its own port and reverse-proxies /v1/* to the control plane.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-vitest.mjs"
  },
  "dependencies": {
    "@fastify/http-proxy": "^11.5.0",
    "@fastify/static": "^8.2.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "fastify-metrics": "^13.2.0",
    "zod": "^3.25.36"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
