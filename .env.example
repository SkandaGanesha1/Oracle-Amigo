SANDBOX_DRY_RUN=true
SANDBOX_HOST=127.0.0.1
SANDBOX_PORT=3399
SANDBOX_DEFAULT_TTL_SECONDS=1800
SANDBOX_MAX_COMMAND_LENGTH=4000
SANDBOX_MAX_TIMEOUT_MS=120000
GITHUB_TOKEN=
NPM_TOKEN=

# ----------------------------
# OCI Generative AI
# ----------------------------
OCI_GENAI_MODEL_ID="openai.gpt-5.2"
OCI_GENAI_SERVICE_ENDPOINT=...
OCI_GENAI_COMPARTMENT_ID=...
OCI_AUTH_TYPE="API_KEY" # [API_KEY, INSTANCE_PRINCIPAL]
# Optional (for API_KEY auth):
OCI_CONFIG_FILE=...
OCI_CONFIG_PROFILE="DEFAULT"    