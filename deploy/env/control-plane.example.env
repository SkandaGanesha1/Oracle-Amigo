# Pilot LAN defaults. Replace all secrets before real shared use.
NODE_ENV=development
CONTROL_PLANE_ENV=development
CONTROL_PLANE_DEPLOYMENT_TIER=pilot
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8080
CONTROL_PLANE_PUBLIC_URL=http://localhost:8088
CONTROL_PLANE_ALLOW_INSECURE_PUBLIC_URL=true
CONTROL_PLANE_DB_DRIVER=postgres
POSTGRES_USER=oracle_amigo
POSTGRES_PASSWORD=PilotPostgresPassword-rotate-before-shared-use-2026
POSTGRES_DB=oracle_amigo
CONTROL_PLANE_DATABASE_URL=postgres://oracle_amigo:PilotPostgresPassword-rotate-before-shared-use-2026@postgres:5432/oracle_amigo
FILE_TRANSFER_STORE=/app/data/transfers
DEFAULT_ORG_SLUG=pilot

JWT_ACCESS_SECRET=PilotAccessSecret-rotate-before-shared-use-2026
JWT_REFRESH_SECRET=PilotRefreshSecret-rotate-before-shared-use-2026
TRANSFER_KEK=PilotTransferKek-rotate-before-shared-use-2026
ADMIN_KEK=PilotAdminKek-rotate-before-shared-use-2026
ADMIN_COOKIE_HOST_PREFIX=false
ADMIN_SETUP_ENABLED=true
METRICS_ENABLED=true
